# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/huawei_autopublish"

# OpenAI (GPT-4o for metadata generation, translation, and DALL-E for fallback images)
OPENAI_API_KEY=""

# Huawei AppGallery Connect API
# Get these from: Console → Users and permissions → API key → Connect API
HUAWEI_AGC_CLIENT_ID=""
HUAWEI_AGC_CLIENT_SECRET=""
HUAWEI_AGC_TEAM_ID=""

# VMOS Cloud (preferred for real-device screenshots — install APK on a
# user-provisioned pad and capture frames). Get AK/SK from
# https://cloud.vmoscloud.com/openapi
VMOSCLOUD_ACCESS_KEY_ID=""
VMOSCLOUD_SECRET_ACCESS_KEY=""
# padCode of the existing VMOS device that will host the APK during screenshot
# capture. Visible in your VMOS console → My devices.
VMOSCLOUD_PAD_CODE=""
# Public URL where this app is reachable so VMOS can pull the APK
# (defaults to NEXT_PUBLIC_APP_URL if unset).
APP_PUBLIC_URL=""

# Appetize.io (optional fallback for real Android emulator screenshots)
# Skip to fall back to template-based mockups
APPETIZE_API_TOKEN=""

# App config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
UPLOAD_DIR="./uploads"

# Worker
WORKER_POLL_INTERVAL_MS="5000"
